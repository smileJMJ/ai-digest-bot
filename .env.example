# ── Slack ────────────────────────────────────────────
# Slack 앱의 Bot User OAuth Token (xoxb-로 시작)
SLACK_BOT_TOKEN=xoxb-your-token-here

# 메시지를 전송할 Slack 채널 이름 (없으면 자동 생성)
SLACK_CHANNEL_NAME=ai-digest

# ── Google Gemini ─────────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-key-here

# ── Tavily (웹 검색) ──────────────────────────────────
# Tavily 대시보드에서 발급: https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── 수집/요약 제한 ────────────────────────────────────
# 1회 전송 시 최대 메시지 수 (최대 20)
MAX_ITEMS_PER_DIGEST=20

# 요약 최대 글자 수
MAX_SUMMARY_CHARS=500
