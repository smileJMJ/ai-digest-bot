# ── Slack ────────────────────────────────────────────
# Slack 앱의 Bot User OAuth Token (xoxb-로 시작)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack 앱의 Signing Secret (Interactive Components 요청 검증)
# Slack App 설정 > Basic Information > App Credentials에서 확인
SLACK_SIGNING_SECRET=your-signing-secret-here

# 메시지를 전송할 Slack 채널 이름 (없으면 자동 생성)
SLACK_CHANNEL_NAME=ai-digest

# ── Google Gemini ─────────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-key-here

# ── Tavily (웹 검색) ──────────────────────────────────
# Tavily 대시보드에서 발급: https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── Notion ────────────────────────────────────────────
# Notion Integration Token
# 발급: https://www.notion.so/my-integrations > New integration
NOTION_API_KEY=secret_your-key-here

# 저장 대상 Notion Database ID
# Database URL에서 추출: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=your-database-id-here

# ── 스케줄러 ──────────────────────────────────────────
# 전송 간격 (시간 단위, 기본 12)
SCHEDULE_INTERVAL_HOURS=12

# ── 수집/요약 제한 ────────────────────────────────────
# 1회 전송 시 최대 메시지 수 (최대 20)
MAX_ITEMS_PER_DIGEST=20

# 요약 최대 글자 수
MAX_SUMMARY_CHARS=500

# ── 서버 ──────────────────────────────────────────────
# FastAPI 서버 포트 (Slack Interactive Components 수신)
PORT=8000
